# ===== Продакшн-настройки инстанса =====
# Скопируйте в файл .env рядом с docker-compose.prod.yml и заполните своими
# значениями. Пароли/секреты — длинные и случайные (см. подсказки ниже).
# Файл .env НЕ коммитить в git.

# Публичный порт приложения. Слушается ТОЛЬКО на 127.0.0.1, наружу отдаёт nginx.
APP_PORT=8080

# --- База данных (контейнер MariaDB) ---
DB_NAME=fp_site
DB_USER=fp
# Сгенерировать: openssl rand -hex 24
DB_PASSWORD=ЗАМЕНИТЕ_надёжный_пароль_БД
DB_ROOT_PASSWORD=ЗАМЕНИТЕ_надёжный_root_пароль

# --- Секрет для подписи JWT админки ---
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИТЕ_openssl_rand_hex_32

# --- Учётная запись администратора ---
# Создаётся при первом старте, если пользователя с таким email ещё нет.
# При повторных запусках существующий админ НЕ перезаписывается.
ADMIN_EMAIL=admin@ваш-домен.ru
ADMIN_PASSWORD=ЗАМЕНИТЕ_надёжный_пароль_админа

# --- POS-интеграция ---
# mock — демо-меню без POS; fusionpos — реальная интеграция.
# Драйвер и токен можно задать здесь ИЛИ позже в админке (Настройки).
# Значение из БД имеет приоритет над этими переменными.
POS_DRIVER=mock
FUSIONPOS_BASE_URL=
FUSIONPOS_TOKEN=

# Уведомления в MAX (токен бота и чат) задаются ТОЛЬКО в админке → Настройки,
# они хранятся в БД и здесь не указываются.
