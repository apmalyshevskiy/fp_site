# ===== Прод-настройки, вариант Б: БД на хосте =====
# Скопируйте в .env рядом с docker-compose.host-db.yml и заполните.
# База данных и пользователь на хостовой MariaDB должны быть созданы заранее
# (см. DEPLOY.md → «Вариант Б»). Файл .env НЕ коммитить в git.

# Публичный порт приложения. Слушается ТОЛЬКО на 127.0.0.1, наружу отдаёт nginx.
APP_PORT=8080

# --- Существующая MariaDB на хосте ---
# host.docker.internal — шлюз Docker к хосту. Если MariaDB слушает только
# 127.0.0.1, укажите адрес docker-моста (обычно 172.17.0.1) и разрешите его
# в bind-address и грантах пользователя.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=fp_site
DB_USER=fp
DB_PASSWORD=ЗАМЕНИТЕ_пароль_пользователя_БД

# --- Секрет для подписи JWT админки (openssl rand -hex 32) ---
JWT_SECRET=ЗАМЕНИТЕ_openssl_rand_hex_32

# --- Учётная запись администратора (создаётся при первом старте, если её нет) ---
ADMIN_EMAIL=admin@ваш-домен.ru
ADMIN_PASSWORD=ЗАМЕНИТЕ_надёжный_пароль_админа

# --- POS-интеграция (можно оставить mock и настроить позже в админке) ---
POS_DRIVER=mock
FUSIONPOS_BASE_URL=
FUSIONPOS_TOKEN=

# Уведомления в MAX задаются в админке → Настройки (хранятся в БД).
