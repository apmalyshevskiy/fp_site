# Конфигурация инстанса для docker-compose (один ресторан = один такой файл)
APP_PORT=8080

DB_NAME=fp_site
DB_USER=fp
DB_PASSWORD=fp_password
DB_ROOT_PASSWORD=root_password

# Обязательно задать уникальный секрет
JWT_SECRET=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# mock — демо-меню без POS; fusionpos — реальная интеграция
POS_DRIVER=mock
FUSIONPOS_BASE_URL=
FUSIONPOS_TOKEN=
