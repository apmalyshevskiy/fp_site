# Порт HTTP-сервера
PORT=3000

# Подключение к MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fp
DB_PASSWORD=fp_password
DB_NAME=fp_site

# Секрет для подписи JWT админки (обязательно поменять на проде)
JWT_SECRET=change-me-in-production

# Учётка администратора, создаётся при первом запуске (seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Драйвер интеграции с POS: mock | fusionpos
POS_DRIVER=mock

# Настройки FUSIONPOS (для POS_DRIVER=fusionpos)
FUSIONPOS_BASE_URL=https://api.fusionpos.ru
FUSIONPOS_TOKEN=
